// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleEnum {
  AGENT
  SUPERVISOR
  ADM
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  VACANT_LOT
  STRATEGIC_POINT
  HEALTH_FACILITY
  SCHOOL
  OTHER
}

enum VisitType {
  ROUTINE
  RECOVERY
  LIRAA
  BLOCKING
}

enum PendingReason {
  NONE
  REFUSED
  CLOSED
  ABSENT
  ABANDONED
  OTHER
}

enum DepositType {
  A1
  A2
  B
  C
  D1
  D2
  E
}

enum LarvicideType {
  NONE
  BTI
  PYRIPROXYFEN
  DIFLUBENZURON
  TEMEPHOS
  OTHER
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  phoneNumber  String
  role         RoleEnum
  banned       Boolean  @default(false)
  createdAt    DateTime @default(now())

  // ===== AGENT =====
  block String?

  // ===== AGENT & SUPERVISOR =====
  registration String?

  refreshTokens RefreshToken[]

  visitForms VisitForm[]

  // ===== ADMIN =====
  accessLevel Int?

  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model VisitForm {
  id String @id @default(uuid())

  visitDate     DateTime
  localityCode  String
  streetName    String
  number        String
  blockSide     String?
  complement    String?
  propertyType  PropertyType
  residentName  String?
  phone         String?
  entryTime     String?
  visitType     VisitType
  inspected     Boolean
  pendingReason PendingReason?

  depositsWithFocus  Boolean
  depositType        DepositType?
  larvicideUsed      LarvicideType?
  treatedDeposits    Int
  eliminatedDeposits Int

  depositsA1 Int
  depositsA2 Int
  depositsB  Int
  depositsC  Int
  depositsD1 Int
  depositsD2 Int
  depositsE  Int

  treatmentApplied       Boolean
  treatmentLarvicideType LarvicideType?
  larvicideAmount        Float?
  perifocalDeposits      Int
  adulticideLoads        Int

  sampleCollected Boolean
  sampleCode      String?
  tubeCount       Int

  notes String?

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([visitDate])
}
